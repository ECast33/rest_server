# Copy this file to `.env` and fill in real values for your environment.
# `.env` is gitignored and should never be committed with real secrets.

# OpenID Connect Provider settings
OIDC_ISSUER=http://localhost:8080/realms/imitate
OIDC_CLIENT_ID=imitate-app
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:8000/api/v1/auth/callback

# Scopes requested from the IdP (openid is required; profile/email for user info)
OIDC_SCOPE=openid profile email

# JWT settings for app-issued tokens
JWT_SECRET=
JWT_EXPIRY=1h
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=7d

# Where the Angular SPA lives — the callback redirects here with the token
FRONTEND_CALLBACK_URL=http://localhost:4200/auth/callback

# Origin allowed by CORS for the frontend app
FRONTEND_ORIGIN=http://localhost:4200

# Server clustering
CLUSTERING_ENABLED=false
WORKER_PER_CPU=1

# MySQL connection settings
DB_HOST=localhost
DB_PORT=3306
DB_NAME=user_auth
DB_CONNECTION_LIMIT=1

# App-level MySQL user (used by the connection pool / query service)
DB_USER=imitate
DB_PASSWORD=

# Root/admin MySQL user (used by the session store and TypeORM data source)
DB_ROOT_USER=root
DB_ROOT_PASSWORD=

# Express session secret
SESSION_SECRET=

# TLS settings (optional)
TLS_KEY=
TLS_CERT=
TLS_PASSPHRASE=

# Default seeded account passwords (change immediately after first login)
DEFAULT_ROOT_PASSWORD=
DEFAULT_ADMIN_PASSWORD=

# Node environment
# Leave unset (or blank) for local development: packages/server/config/standard
# stores config files flatly (no per-environment subfolder), and app-config only
# looks for an env subfolder when NODE_ENV is set. Use NODE_ENV=testing to run
# the test suite (see packages/server/config/testing).
NODE_ENV=
